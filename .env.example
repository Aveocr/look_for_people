# Example .env file for look_for_people web app
# Path to default ONNX model for CLIP-ReID (optional)
MODEL_ONNX=model.onnx
# Path to default TensorRT engine (optional)
MODEL_TRT=
# Default gallery directory containing person subfolders
GALLERY_DIR=data/persons
# Default target directory (images of person to search)
TARGET_DIR=target
# Use CUDA for ONNX runtime (true/false)
USE_CUDA=false
